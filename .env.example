# GapHunter Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Required for LIVE mode ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
SERPAPI_KEY=...
GOOGLE_CSE_KEY=...                    # Google Cloud API key with Search Console scope
GOOGLE_CSE_ID=...                     # Your GSC property (e.g. sc-domain:yoursite.com)
GOOGLE_SERVICE_ACCOUNT=./secrets/gsc_service_account.json

# ── Optional monetization ─────────────────────────────────
AMAZON_ASSOCIATES_ID=your-tag-20
COUPANG_PARTNERS_ID=...

# ── TimesFM Colab server (Phase 3) ────────────────────────
COLAB_PREDICTOR_URL=https://xxxx.ngrok-free.app   # Set after starting Colab server

# ── Cost control overrides (optional) ────────────────────
MAX_KEYWORDS_PER_RUN=3
MAX_SERPAPI_CALLS_PER_DAY=10
MAX_CLAUDE_CALLS_PER_RUN=5

# ── Mode: set to false only when all keys are ready ───────
DRY_RUN_MODE=true

# ── pytrends rate limiting ────────────────────────────────
PYTRENDS_DELAY_MIN=2
PYTRENDS_DELAY_MAX=7
PYTRENDS_MAX_RETRIES=5
